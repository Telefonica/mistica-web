{
    "name": "DataCard",
    "import": "import {DataCard} from '@telefonica/mistica'",
    "description": "",
    "props": [
        {
            "name": "aria-label",
            "type": "string",
            "required": false
        },
        {
            "name": "aria-labelledby",
            "type": "string",
            "required": false
        },
        {
            "name": "aria-description",
            "type": "string",
            "required": false
        },
        {
            "name": "aria-describedby",
            "type": "string",
            "required": false
        },
        {
            "name": "size",
            "type": "enum",
            "required": false,
            "default": "default"
        },
        {
            "name": "width",
            "type": "string | number",
            "required": false
        },
        {
            "name": "height",
            "type": "string | number",
            "required": false
        },
        {
            "name": "backgroundColor",
            "type": "string",
            "required": false
        },
        {
            "name": "variant",
            "type": "enum",
            "required": false
        },
        {
            "name": "isInverse",
            "type": "boolean",
            "required": false,
            "description": "@deprecated use variant=\"brand\" instead"
        },
        {
            "name": "asset",
            "type": "ReactElement<unknown, string | JSXElementConstructor<any>>",
            "required": false
        },
        {
            "name": "headline",
            "type": "string | RendersNullableElement<({ Icon, children, dataAttributes, type, badge, backgroundColor: customBackgroundColor, textColor: customTextColor, small, }: TagProps) => Element | null>",
            "required": false
        },
        {
            "name": "pretitle",
            "type": "string",
            "required": false
        },
        {
            "name": "pretitleAs",
            "type": "enum",
            "required": false
        },
        {
            "name": "pretitleLinesMax",
            "type": "number",
            "required": false
        },
        {
            "name": "title",
            "type": "string",
            "required": false
        },
        {
            "name": "titleAs",
            "type": "enum",
            "required": false
        },
        {
            "name": "titleLinesMax",
            "type": "number",
            "required": false
        },
        {
            "name": "subtitle",
            "type": "string",
            "required": false
        },
        {
            "name": "subtitleLinesMax",
            "type": "number",
            "required": false
        },
        {
            "name": "description",
            "type": "string",
            "required": false
        },
        {
            "name": "descriptionLinesMax",
            "type": "number",
            "required": false
        },
        {
            "name": "dataAttributes",
            "type": "DataAttributes",
            "required": false
        },
        {
            "name": "extraAlignment",
            "type": "enum",
            "required": false
        },
        {
            "name": "extra",
            "type": "ReactNode",
            "required": false,
            "description": "@deprecated use slot"
        },
        {
            "name": "slot",
            "type": "ReactNode",
            "required": false
        },
        {
            "name": "slotAlignment",
            "type": "enum",
            "required": false,
            "default": "bottom"
        },
        {
            "name": "aspectRatio",
            "type": "CardAspectRatio",
            "required": false
        },
        {
            "name": "button",
            "type": "CardActionButtonPrimary",
            "required": false,
            "description": "@deprecated use buttonPrimary or buttonSecondary"
        },
        {
            "name": "buttonPrimary",
            "type": "CardActionButtonPrimary",
            "required": false
        },
        {
            "name": "buttonSecondary",
            "type": "CardActionButtonSecondary",
            "required": false
        },
        {
            "name": "buttonLink",
            "type": "CardActionButtonLink",
            "required": false
        },
        {
            "name": "onClose",
            "type": "(() => unknown)",
            "required": false
        },
        {
            "name": "closeButtonLabel",
            "type": "string",
            "required": false
        },
        {
            "name": "actions",
            "type": "TopActionsArray",
            "required": false,
            "description": "@deprecated use topActions"
        },
        {
            "name": "topActions",
            "type": "TopActionsArray",
            "required": false
        },
        {
            "name": "showFooter",
            "type": "boolean",
            "required": false
        },
        {
            "name": "footerBackgroundColor",
            "type": "string",
            "required": false
        },
        {
            "name": "footerVariant",
            "type": "enum",
            "required": false
        },
        {
            "name": "footerSlot",
            "type": "ReactNode",
            "required": false
        },
        {
            "name": "footerDivider",
            "type": "boolean",
            "required": false
        },
        {
            "name": "href",
            "type": "string",
            "required": false
        },
        {
            "name": "newTab",
            "type": "boolean",
            "required": false
        },
        {
            "name": "loadOnTop",
            "type": "boolean",
            "required": false
        },
        {
            "name": "onNavigate",
            "type": "(() => void | Promise<void>) | (() => void | Promise<void>)",
            "required": false
        },
        {
            "name": "to",
            "type": "string",
            "required": false
        },
        {
            "name": "fullPageOnWebView",
            "type": "boolean",
            "required": false
        },
        {
            "name": "replace",
            "type": "boolean",
            "required": false
        },
        {
            "name": "onPress",
            "type": "PressHandler",
            "required": false
        },
        {
            "name": "trackingEvent",
            "type": "TrackingEvent | readonly TrackingEvent[]",
            "required": false
        },
        {
            "name": "role",
            "type": "string",
            "required": false
        },
        {
            "name": "aria-current",
            "type": "boolean | \"false\" | \"true\" | \"page\" | \"step\" | \"location\" | \"date\" | \"time\"",
            "required": false
        },
        {
            "name": "touchableAriaLabel",
            "type": "string",
            "required": false,
            "description": "Aria label for the touchable element. If set the whole card will be announced as a link/button by screen readers."
        },
        {
            "name": "segregateTouchableContent",
            "type": "boolean",
            "required": false,
            "description": "When true, the touchable content of the card will be segregated for screen readers. Only one of those elements will be announced as link/button,\naccording to the following logic:\n- If there is title or pretitle it will be the one between these two with the higher hierarchy (for example, if titleAs is 'h2' and pretitleAs is 'h3', the title will be the touchable element).\n- If those are not present it will be the next hierarchy element: headline, subtitle, ...\nThis behaviour can be overriden with the touchableAriaLabel prop."
        }
    ],
    "playroomSnippet": "<DataCard\n            asset={\n                <Circle backgroundColor={colors.brandLow} size={40}>\n                    <IconShopRegular color={colors.brand} />\n                </Circle>\n            }\n            headline={<Tag type=\"promo\">Headline</Tag>}\n            title=\"Title\"\n            subtitle=\"Subtitle\"\n            description=\"Description\"\n            slot={<Placeholder />}\n            buttonPrimary={\n                <ButtonPrimary small onPress={() => {}}>\n                    Action\n                </ButtonPrimary>\n            }\n            buttonLink={<ButtonLink small onPress={() => {}}>Link</ButtonLink>}\n        />"
}
