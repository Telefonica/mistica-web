{
  "projectId": "f89f58fb-1a7c-4bea-ac56-84fcdbec0a3e",
  "pkg": "@telefonica/mistica",
  "globalName": "Mistica",
  "shape": "storybook",
  "storybookConfigDir": ".storybook",
  "storybookStatic": ".design-sync/sb-reference",
  "entry": ".design-sync/ds-entry.js",
  "cssEntry": ".design-sync/ds-styles.css",
  "extraFonts": ".storybook/css/onair-font.css",
  "readmeHeader": ".design-sync/conventions.md",
  "buildCmd": "yarn build",
  "extraEntries": ["./.design-sync/preview-theme.js"],
  "provider": {
    "component": "ThemeContextProvider",
    "props": {"theme": {"$ref": "previewTheme"}},
    "inner": {"component": "OverscrollColorProvider"}
  },
  "storyImports": {
    "loaders": {".jpg": "file", ".jpeg": "file", ".mp4": "file"}
  },
  "libOverrides": {
    "story-imports.mjs": "kebab-case source files (icon-button.tsx) export PascalCase (IconButton); map kebab->Pascal so path imports shim to the global instead of bundling .css.ts source",
    "previews.mjs": "set esbuild publicPath so file-loader image/video assets (large demo JPEGs) resolve as ../../../_preview/ from the 3-deep component HTML"
  },
  "overrides": {
    "ButtonPrimary": {"cardMode": "column"},
    "CreditCardExpirationField": {"cardMode": "column"},
    "CreditCardNumberField": {"cardMode": "column"},
    "CvvField": {"cardMode": "column"},
    "DateField": {"cardMode": "column"},
    "DateTimeField": {"cardMode": "column"},
    "DecimalField": {"cardMode": "column"},
    "DoubleField": {"cardMode": "column"},
    "EmailField": {"cardMode": "column"},
    "GridLayout": {"cardMode": "column"},
    "IbanField": {"cardMode": "column"},
    "Inline": {"cardMode": "column"},
    "IntegerField": {"cardMode": "column"},
    "MonthField": {"cardMode": "column"},
    "PasswordField": {"cardMode": "column"},
    "PhoneNumberField": {"cardMode": "column"},
    "PhoneNumberFieldLite": {"cardMode": "column"},
    "Popover": {"cardMode": "column"},
    "SearchField": {"cardMode": "column"},
    "Select": {"cardMode": "column"},
    "Sheet": {"cardMode": "column"},
    "Text": {"cardMode": "column"},
    "TextField": {"cardMode": "column"},
    "ThemeVariant": {"cardMode": "column"},
    "TimeField": {"cardMode": "column"},
    "Tooltip": {"cardMode": "column"},
    "FeedbackScreen": {"cardMode": "single"},
    "FixedToTop": {"cardMode": "single"},
    "FunnelNavigationBar": {"cardMode": "single"},
    "MainNavigationBar": {"cardMode": "single"},
    "NavigationBar": {"cardMode": "single"}
  },
  "titleMap": {
    "Accordions": "Accordion",
    "Buttons": "ButtonPrimary",
    "Breadcrumbs": "NavigationBreadcrumbs",
    "Lists": "RowList",
    "Mosaic": "HorizontalMosaic",
    "Progressbars": "ProgressBar",
    "Titles": "Title1",
    "Buttonlayout": "ButtonLayout",
    "Gridlayout": "GridLayout",
    "Doublefield": "DoubleField",
    "Masterdetaillayout": "MasterDetailLayout",
    "Responsivelayout": "ResponsiveLayout",
    "Formwithautomaticstatemanagement": "Form",
    "Welcome": null,
    "Catalog": null,
    "Loading": null,
    "Modals": null,
    "Inputfieldwithcustomformatter": null,
    "Formwitherrorhandler": null,
    "Formwithmanualstatemanagement": null,
    "Formwithsubmitbuttoninfixedfooter": null,
    "ExampleComponent": null,
    "AdvancedDataCard": null,
    "AdvancedDataCardsinCarousel": null,
    "AiCard": null,
    "Blocks": null,
    "OverscrollColor": null,
